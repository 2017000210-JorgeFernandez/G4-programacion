Algoritmo SH9
	
    Definir num, suma Como Entero
	
    suma <- 0
	
    Escribir "Nombre: Jorge Fernandez"
	
    Repetir
		
        Escribir "Ingrese un numero:"
        Leer num
		
        suma <- suma + num
		
    Hasta Que num = 9
	
    Escribir "La suma total es: ", suma
	
FinAlgoritmo