Algoritmo E
	
    Definir cajones Como Entero
	
    cajones <- 200
	
    Escribir "Nombre: Jorge Fernandaez"
	
    Repetir
		
        Escribir "Cajones disponibles: ", cajones
		
        cajones <- cajones - 1
		
    Hasta Que cajones = 0
	
    Escribir "Ya no hay cajones libres"
	
FinAlgoritmo